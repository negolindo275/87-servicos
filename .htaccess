.htaccess
# Ativar mod_rewrite
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirecionar /admin/api/* para api/admin-save.php
  RewriteRule ^admin/api/(.*)$ api/admin-save.php [QSA,L]

  # Redirecionar /.netlify/functions/chat para api/chat.php (compatibilidade)
  RewriteRule ^\.netlify/functions/chat$ api/chat.php [QSA,L]

  # Bloquear acesso direto a arquivos sensíveis
  RewriteRule ^api/config\.php$ - [F]
  RewriteRule ^admin/config\.yml$ - [F]
  
  # Impedir acesso a diretórios sensíveis
  RewriteRule ^\.git - [F]
  RewriteRule ^node_modules - [F]
  RewriteRule ^data/logs - [F]
</IfModule>

# Cache headers para assets
<FilesMatch "\.(jpg|jpeg|png|gif|ico|css|js)$">
  Header set Cache-Control "max-age=31536000, public"
</FilesMatch>

# Desativar cache para JSON dinâmico
<FilesMatch "\.json$">
  Header set Cache-Control "no-cache, must-revalidate"
</FilesMatch>

# Compressão GZIP
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>